# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: Token for the Telegram bot to send notifications.
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_CHAT_ID: Chat ID where the bot will send notifications.
TELEGRAM_CHAT_ID=""

# TELEGRAM_USER_BOT_TOKEN: Token for the secondary Telegram bot for user interaction.
TELEGRAM_USER_BOT_TOKEN=""
